{"manifest_version": 3, "name": "AI Text Explainer", "version": "1.0", "description": "选中文本并用本地 AI 模型解释", "permissions": ["activeTab", "scripting", "sidePanel", "storage"], "host_permissions": ["http://127.0.0.1:8000/*"], "action": {"default_popup": "popup.html", "default_icon": {"16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png"}}, "side_panel": {"default_path": "sidebar.html"}, "content_scripts": [{"matches": ["<all_urls>"], "js": ["content.js"]}], "background": {"service_worker": "background.js"}, "icons": {"16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png"}}